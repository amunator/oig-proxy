{
  "name": "OIG Proxy amunator version",
  "version": "2.0.11",
  "slug": "oig_proxy",
  "description": "OIG TCP proxy v2 – async architektura, MQTT, HA discovery",
  "arch": ["amd64", "aarch64"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "hassio_api": false,
  "homeassistant_api": false,
  "host_network": true,
  "options": {
    "target_server": "bridge.oigpower.cz",
    "target_port": 5710,
    "proxy_port": 5710,
    "proxy_mode": "online",
    "cloud_ack_timeout": 1800.0,
    "hybrid_retry_interval": 60,
    "hybrid_fail_threshold": 1,
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_username": "",
    "mqtt_password": "",
    "ha_ip": "",
    "dns_override_ip": "",
    "dns_upstream": "8.8.8.8",
    "log_level": "INFO",
    "proxy_status_interval": 60,
    "full_refresh_interval_hours": 24,
    "capture_payloads": false,
    "capture_raw_bytes": false,
    "capture_retention_days": 7,
    "capture_pcap": false,
    "control_mqtt_enabled": false,
    "telemetry_enabled": true,
    "max_concurrent_connections": 5
  },
  "schema": {
    "target_server": "str",
    "target_port": "int",
    "proxy_port": "int",
    "proxy_mode": "list(online|hybrid|offline)",
    "cloud_ack_timeout": "float",
    "hybrid_retry_interval": "int",
    "hybrid_fail_threshold": "int",
    "mqtt_host": "str",
    "mqtt_port": "int",
    "mqtt_username": "str",
    "mqtt_password": "str",
    "ha_ip": "str?",
    "dns_override_ip": "str?",
    "dns_upstream": "str?",
    "log_level": "list(INFO|DEBUG|TRACE)",
    "proxy_status_interval": "int",
    "full_refresh_interval_hours": "int",
    "capture_payloads": "bool?",
    "capture_raw_bytes": "bool?",
    "capture_retention_days": "int?",
    "capture_pcap": "bool?",
    "control_mqtt_enabled": "bool?",
    "telemetry_enabled": "bool?",
    "max_concurrent_connections": "int?"
  },
  "ports": {
    "5710/tcp": 5710,
    "53/udp": 53,
    "53/tcp": 53
  },
  "map": ["data:rw"]
}
